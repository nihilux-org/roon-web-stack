{
  "name": "@nihilux/roon-web-client",
  "version": "0.0.14",
  "main": "bin/roon-web-client.js",
  "typings": "bin/index.d.ts",
  "license": "MIT",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./bin/src/index.d.ts",
      "import": "./bin/roon-web-client.js",
      "default": "./bin/roon-web-client.js"
