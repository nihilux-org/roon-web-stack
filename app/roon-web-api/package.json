{
  "name": "@nihilux/roon-web-api",
  "version": "0.0.13",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "bun run src/build.ts binary",
    "build:debug": "bun run src/build.ts debug",
    "lint": "bun run eslint .",
    "lint:fix": "bun run eslint . --fix",
    "start": "NODE_ENV=development LOG_LEVEL=debug  bun run --watch --inspect src/index.ts",
    "test": "vitest --coverage",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@nihilux/roon-web-model": "workspace:*",
    "hono": "4.12.12",
    "nanoid": "5.1.7",
    "node-roon-api": "github:roonlabs/node-roon-api",
    "node-roon-api-audioinput": "github:roonlabs/node-roon-api-audioinput",
    "node-roon-api-browse": "github:roonlabs/node-roon-api-browse",
    "node-roon-api-image": "github:roonlabs/node-roon-api-image",
    "node-roon-api-settings": "github:roonlabs/node-roon-api-settings",
    "node-roon-api-status": "github:roonlabs/node-roon-api-status",
    "node-roon-api-transport": "github:roonlabs/node-roon-api-transport",
    "pino": "10.3.1",
    "rxjs": "7.8.2",
    "ts-retry-promise": "0.8.1",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bun": "1.3.11",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@vitest/coverage-istanbul": "4.1.4",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "prettier": "3.8.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.1",
    "vitest": "4.1.4"
  }
}
